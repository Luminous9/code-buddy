{
  "name": "code-buddy",
  "version": "0.3.0",
  "description": "Permanent coding companion for Claude Code — survives any update (MVP)",
  "type": "module",
  "bin": {
    "code-buddy": "./cli/index.ts"
  },
  "scripts": {
    "server": "bun run server/index.ts",
    "pick": "bun run cli/pick.ts",
    "pull": "bun run cli/pull.ts",
    "pull:claude": "bun run cli/pull.ts --llm claude",
    "pull:codex": "bun run cli/pull.ts --llm codex",
    "hunt": "bun run cli/hunt.ts",
    "install-buddy": "bun run cli/install.ts",
    "show": "bun run cli/show.ts",
    "doctor": "bun run cli/doctor.ts",
    "test-statusline": "bun run cli/test-statusline.ts",
    "backup": "bun run cli/backup.ts",
    "settings": "bun run cli/settings.ts",
    "disable": "bun run cli/disable.ts",
    "enable": "bun run cli/install.ts",
    "upgrade": "bun run cli/upgrade.ts",
    "uninstall": "bun run cli/uninstall.ts",
    "help": "bun run cli/index.ts help",
    "buddy-shell": "npx tsx cli/buddy-shell.ts",
    "tui": "bun run cli/tui.tsx",
    "new-species": "bun run scripts/species-tool.ts new",
    "import-species": "bun run scripts/species-tool.ts",
    "delete-species": "bun run scripts/species-tool.ts delete",
    "preview-species": "bun run scripts/species-tool.ts preview",
    "gen-shell-art": "bun run scripts/gen-shell-art.ts",
    "export-reactions": "bun run scripts/export-reactions.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "server/",
    "cli/",
    "skills/",
    "hooks/",
    "statusline/",
    ".claude-plugin/",
    "!**/*.test.ts"
  ],
  "keywords": [
    "claude-code",
    "buddy",
    "companion",
    "mcp",
    "terminal-pet",
    "tamagotchi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Luminous9/code-buddy.git"
  },
  "homepage": "https://github.com/Luminous9/code-buddy#readme",
  "license": "MIT",
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "@homebridge/node-pty-prebuilt-multiarch"
  ]
}
